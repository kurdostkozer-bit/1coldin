{
  "name": "kurdbox",
  "publisher": "kurdost",
  "displayName": "KurdBox AI",
  "description": "AI Chat & Inline Completions powered by KURDOST Gateway",
  "version": "1.0.3",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "updateUrl": "https://marketplace.visualstudio.com/items?itemName=kurdost.kurdbox",
  "repository": {
    "type": "git",
    "url": "https://github.com/kurdost/kurdbox"
  },
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kurdbox.openChat",
        "title": "KurdBox: Open Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "kurdbox.openAgent",
        "title": "KurdBox: Open Agent",
        "icon": "$(robot)"
      },
      {
        "command": "kurdbox.setServer",
        "title": "KurdBox: Set Server URL"
      },
      {
        "command": "kurdbox.clearChat",
        "title": "KurdBox: Clear Chat"
      },
      {
        "command": "kurdbox.debugError",
        "title": "KurdBox: Debug Error 🔍",
        "icon": "$(bug)"
      },
      {
        "command": "kurdbox.checkUpdates",
        "title": "KurdBox: Check for Updates",
        "icon": "$(sync)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kurdbox",
          "title": "KurdBox AI",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "kurdbox": [
        {
          "type": "webview",
          "id": "kurdbox.chatView",
          "name": "KurdBox AI"
        }
      ]
    },
    "configuration": {
      "title": "KurdBox",
      "properties": {
        "kurdbox.serverUrl": {
          "type": "string",
          "default": "http://localhost:5001",
          "description": "KURDOST server URL (new backend on 5001)"
        },
        "kurdbox.defaultProvider": {
          "type": "string",
          "default": "",
          "description": "Default provider (empty = auto)"
        },
        "kurdbox.defaultModel": {
          "type": "string",
          "default": "best-70b",
          "description": "Default model"
        },
        "kurdbox.inlineCompletions": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline completions"
        },
        "kurdbox.agent.requireCommandConfirmation": {
          "type": "boolean",
          "default": false,
          "description": "Require explicit user confirmation before the agent runs shell commands"
        },
        "kurdbox.chat.includeWorkspaceContext": {
          "type": "boolean",
          "default": false,
          "description": "Attach workspace summary (active file path only) to chat messages. Off by default to keep responses fast and accurate."
        },
        "kurdbox.chat.autoAgentRouting": {
          "type": "boolean",
          "default": false,
          "description": "Automatically route coding tasks to Agent mode. When off, all messages use Chat."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "kurdbox.clearChat",
          "when": "view == kurdbox.chatView",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "kurdbox.openChat",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k"
      },
      {
        "command": "kurdbox.debugError",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d"
      },
      {
        "command": "kurdbox.openAgent",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "node --no-experimental-strip-types node_modules/mocha/bin/mocha.js --require ts-node/register \"src/**/*.test.ts\" --timeout 60000",
    "package": "vsce package",
    "dev": "powershell -ExecutionPolicy Bypass -File ./watch-reload.ps1",
    "quick-reload": "npm run compile && npm run package && code --install-extension ./kurdbox-1.0.1.vsix --force"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@typescript-eslint/typescript-estree": "^8.62.0",
    "@vscode/vsce": "^2.22.0",
    "ast-types": "^0.16.1",
    "diff": "^9.0.0",
    "fast-check": "^4.8.0",
    "fast-diff": "^1.3.0",
    "jest": "^30.4.2",
    "mocha": "^11.7.6",
    "recast": "^0.23.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "lowdb": "^7.0.1",
    "mysql2": "^3.22.5",
    "pg": "^8.22.0",
    "typescript": "^5.9.3",
    "uuid": "^14.0.1"
  }
}
