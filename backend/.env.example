# KurdBox Backend — Environment Variables
# Copy this to .env and fill in the values

# Server
HOST=127.0.0.1
PORT=5001
CORS_ORIGINS=http://localhost:5001,http://localhost:5000

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite:///./kurdbox.db

# JWT Secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
KURDOST_SECRET_KEY=

# Encryption key for API keys — generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
KURDOST_ENC_KEY=

# Demo mode — enables /auth/demo-token endpoint (dev only, set false in production)
DEMO_MODE=false
